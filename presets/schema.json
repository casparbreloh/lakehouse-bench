{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lakehouse Bench preset",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "name", "cloud", "workload", "profile", "topology", "execution", "publish"],
  "properties": {
    "$schema": {"const": "schema.json"},
    "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"},
    "cloud": {"type": "object", "additionalProperties": false, "required": ["server_type", "location", "image"], "properties": {"server_type": {"type": "string", "pattern": "^[a-z0-9-]+$"}, "location": {"type": "string", "pattern": "^[a-z0-9-]+$"}, "image": {"type": "string", "pattern": "^[a-z0-9._-]+$"}}},
    "workload": {"type": "object", "additionalProperties": false, "required": ["name", "scale_factor", "queries"], "properties": {"name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"}, "scale_factor": {"type": "integer", "minimum": 1, "maximum": 100000}, "queries": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^q([1-9]|1[0-9]|2[0-2])$"}}}},
    "storage": {"type": "object", "additionalProperties": false, "required": ["table_format", "file_format"], "properties": {"table_format": {"type": "string"}, "file_format": {"type": "string"}}},
    "engines": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"}},
    "profile": {"enum": ["smoke", "benchmark"]},
    "topology": {"enum": ["single-node"]},
    "execution": {"type": "object", "additionalProperties": false, "required": ["threads", "warmups", "iterations"], "properties": {"threads": {"type": "integer", "minimum": 1, "maximum": 1024}, "warmups": {"type": "integer", "minimum": 0, "maximum": 100}, "iterations": {"type": "integer", "minimum": 1, "maximum": 100}}},
    "publish": {"type": "object", "additionalProperties": false, "required": ["branch"], "properties": {"branch": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._/-]{0,127}$"}}}
  }
}
